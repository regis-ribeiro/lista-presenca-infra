apiVersion: v1
kind: Pod
metadata:
  name: lista-presenca-pod
  labels:
    app: lista-presenca
spec:
  containers:
    # --- BACKEND (WildFly) ---
    - name: backend
      image: docker.io/reginaldoraraujo/lista-presenca-backend:latest # Ajuste para seu user do Docker Hub
      ports:
        - containerPort: 8080
          hostPort: 30080
      env:
        - name: DB_URL
          value: "jdbc:postgresql://db-postgres:5432/lista_presenca"
        - name: DB_USER
          value: "regis"
        - name: DB_PASS
          value: "root"

    # --- FRONTEND (Nginx) ---
    - name: frontend
      image: docker.io/reginaldoraraujo/lista-presenca-frontend:latest # Ajuste para seu user do Docker Hub
      ports:
        - containerPort: 80
          hostPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: lista-presenca-service
spec:
  type: NodePort
  selector:
    app: lista-presenca
  ports:
    - name: http-front
      port: 80
      nodePort: 30081 # Porta que você acessará no IP do Servidor
    - name: http-back
      port: 8080
      nodePort: 30080
