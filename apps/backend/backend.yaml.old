apiVersion: v1
kind: Pod
metadata:
  name: lista-presenca-backend  # Este nome é o DNS na "minha-rede"
  labels:
    app: backend
spec:
  containers:
    - name: backend
      image: docker.io/reginaldoraraujo/lista-presenca-backend:latest
      env:
        - name: DB_URL
          value: "jdbc:postgresql://db-postgres:5432/lista_presenca"
        - name: DB_USER
          value: "regis"
        - name: DB_PASS
          value: "root"
      ports:
        - containerPort: 8080
          hostPort: 30080
